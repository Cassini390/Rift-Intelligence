RIOT_API_KEY=RGAPI-your-key-here
PORT=3000

# ── Local League Client (LCU) match history — optional, off by default ──────
# Pull match history straight from your running League Client for game modes
# the public Riot API won't serve (e.g. ARAM Mayhem). Requires a separate,
# untracked lcu-local/ folder (not included in this repo) — with it absent
# this simply does nothing. See "Local Client (LCU) match history" in README.md.
ENABLE_LCU=false

# Override these only if auto-detection fails (non-default install location):
# LCU_INSTALL_DIR=C:\Riot Games\League of Legends
# LCU_LOCKFILE=C:\Riot Games\League of Legends\lockfile
